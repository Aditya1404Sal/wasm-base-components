package betty-blocks:auth;

interface jwt {
  use wasi:http/types@0.2.2.{incoming-request};

  variant auth-error {
    malformed-token,
    missing-config(string),
    validation-failed(string),
  }

  record configuration {
    value: string,
    is-encrypted: bool,
  }

  allowed-to-call: func(request: borrow<incoming-request>, action-id: string) -> result<configuration, auth-error>;

  allowed-to-list: func(request: borrow<incoming-request>, mcp-id: string) -> result<bool, auth-error>;
}
