package betty-blocks:data-api;

interface data-api {
  /// TODO : Will be renamed to `data-api-context` after https://github.com/bettyblocks/wasm-base-components/pull/18 (mass mutate) is merged
  record helper-context {
    application-id: string,
    action-id: string,
    log-id: string,
    encrypted-configurations: option<list<string>>,
    jwt: option<string>,
  }

  request: func(helper-context: helper-context, query: string, variables: string) -> result<string, string>;
}

